# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=eramix
DB_USERNAME=eramix_user
DB_PASSWORD=change_me_in_production

# JWT
JWT_SECRET=change_me_use_a_256_bit_random_string
