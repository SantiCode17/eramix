{
  "info": {
    "name": "EraMix – Auth API v1",
    "description": "Colección completa de endpoints de autenticación, seguridad y gestión de sesión de EraMix.\n\nFlujo típico: Register → Login → Refresh → Logout\nFlujo recuperación: Forgot Password → Reset Password\nEliminación: Login → Delete Account\n\nVariables:\n- {{baseUrl}}: URL base del backend (default http://localhost:8080)\n- {{accessToken}}: Se auto-rellena tras register/login/refresh\n- {{refreshToken}}: Se auto-rellena tras register/login/refresh",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "default"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "default"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "default"
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "default"
    }
  ],
  "item": [
    {
      "name": "Auth Flow",
      "description": "Flujo principal de autenticación: registro, login, refresh, logout.",
      "item": [
        {
          "name": "POST /register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@universidad.es\",\n  \"password\": \"SecurePass123!\",\n  \"firstName\": \"Carlos\",\n  \"lastName\": \"García\",\n  \"dateOfBirth\": \"2001-03-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Registra un nuevo usuario. Devuelve access token (JWT, 15 min) y refresh token (UUID, 30 días)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', body.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "    pm.test('Register: 201 Created', () => pm.response.to.have.status(201));",
                  "    pm.test('Has accessToken', () => pm.expect(body.accessToken).to.be.a('string'));",
                  "    pm.test('Has refreshToken', () => pm.expect(body.refreshToken).to.be.a('string'));",
                  "    pm.test('expiresIn is 900', () => pm.expect(body.expiresIn).to.eql(900));",
                  "    pm.test('tokenType is Bearer', () => pm.expect(body.tokenType).to.eql('Bearer'));",
                  "    pm.test('User email matches', () => pm.expect(body.user.email).to.eql('carlos@universidad.es'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /register – Email duplicado (409)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@universidad.es\",\n  \"password\": \"OtherPass456!\",\n  \"firstName\": \"Otro\",\n  \"lastName\": \"User\",\n  \"dateOfBirth\": \"2000-06-20\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Intenta registrar con email ya existente. Espera 409 Conflict."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Duplicate email: 409 Conflict', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /register – Validación (400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"short\",\n  \"firstName\": \"\",\n  \"lastName\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Envía datos inválidos. Espera 400 Bad Request con detalles de validación."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Validation error: 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@universidad.es\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Inicia sesión. Devuelve nuevo par de tokens y actualiza lastSeen."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', body.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "    pm.test('Login: 200 OK', () => pm.response.to.have.status(200));",
                  "    pm.test('Has accessToken', () => pm.expect(body.accessToken).to.be.a('string'));",
                  "    pm.test('lastSeen updated', () => pm.expect(body.user.lastSeen).to.not.be.null);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /login – Credenciales inválidas (401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@universidad.es\",\n  \"password\": \"WrongPassword!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login con contraseña incorrecta. Espera 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid credentials: 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Rota el refresh token: devuelve nuevo par access+refresh, revoca el anterior."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', body.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "    pm.test('Refresh: 200 OK', () => pm.response.to.have.status(200));",
                  "    pm.test('New tokens generated', () => {",
                  "        pm.expect(body.accessToken).to.be.a('string');",
                  "        pm.expect(body.refreshToken).to.be.a('string');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Cierra sesión revocando el refresh token del servidor."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Logout: 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Message present', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message).to.include('correctamente');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Password Recovery",
      "description": "Flujo de recuperación de contraseña: solicitar token → restablecer.",
      "item": [
        {
          "name": "POST /forgot-password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@universidad.es\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "forgot-password"]
            },
            "description": "Genera un token de recuperación (1h). En DEV se devuelve en la respuesta; en PROD se enviaría por email."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('resetToken', body.resetToken);",
                  "    pm.test('Forgot Password: 200', () => pm.response.to.have.status(200));",
                  "    pm.test('Has resetToken', () => pm.expect(body.resetToken).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /reset-password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"NewSecure456!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password"]
            },
            "description": "Restablece la contraseña usando el token. Revoca todos los refresh tokens del usuario."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Reset Password: 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message).to.include('actualizada');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /reset-password – Token inválido (401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"invalid-or-expired-token\",\n  \"newPassword\": \"AnyPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password"]
            },
            "description": "Intenta resetear con token inválido. Espera 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid token: 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Account Management",
      "description": "Gestión de cuenta (requiere JWT en Authorization header).",
      "item": [
        {
          "name": "DELETE /account",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/account",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "account"]
            },
            "description": "Elimina la cuenta permanentemente. Requiere JWT válido y confirmación de contraseña."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Delete Account: 200', () => pm.response.to.have.status(200));",
                  "pm.test('Account deleted message', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message).to.include('eliminada');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /account – Sin auth (401)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"AnyPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/account",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "account"]
            },
            "description": "Intenta eliminar cuenta sin JWT. Espera 401/403."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('No auth: 401 or 403', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health Check",
      "description": "Endpoint público de salud del servicio.",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Devuelve estado del backend. No requiere autenticación."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health: 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Status is UP', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
