{langs.map(l => (

<GlassCard elevated key={l.lang} className="p-4">

<div className="flex items-center gap-3 mb-3">

<span className="text-2xl">{l.flag}</span>

<span className="font-bold" style={{ color: EG.textPrimary, fontFamily: "'Space Grotesk', sans-serif" }}>{l.lang}</span>

<Badge color="blue" className="ml-auto">{l.levelLabel}</Badge>

</div>

<div className="flex gap-1.5">

{Array.from({ length: 6 }).map((_, i) => (

<motion.button

key={i}

className="flex-1 h-8 rounded-xl"

