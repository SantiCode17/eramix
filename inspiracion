const send = () => {

if (!input.trim()) return;

setMessages(prev => [...prev, { id: String(Date.now()), text: input, sender: "me", time: "Now" }]);

setInput("");

setTyping(true);

setTimeout(() => {

setMessages(prev => [...prev, { id: String(Date.now() + 1), text: "¡Genial! Te veo allí 🔥", sender: "other", time: "Now", avatar: user.photo }]);

setTyping(false);

}, 1500);

};



useEffect(() => {

bottomRef.current?.scrollIntoView({ behavior: "smooth" });

}, [messages, typing]);



return (

