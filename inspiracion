style={msg.sender === "me" ? {

background: EG.gradientBlue,

color: EG.textPrimary,

borderBottomRightRadius: "4px",

boxShadow: "0 4px 12px rgba(0,51,153,0.3)",

fontFamily: "'Inter', sans-serif",

} : {

background: EG.glassMid,

backdropFilter: "blur(20px)",

border: `1px solid ${EG.glassBorder}`,

color: EG.textPrimary,

borderBottomLeftRadius: "4px",

fontFamily: "'Inter', sans-serif",

}}

>

{msg.text}

</div>

</motion.div>

))}

</AnimatePresence>



{/* Typing indicator */}

<AnimatePresence>

