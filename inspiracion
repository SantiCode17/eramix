style={{ opacity: nopeOpacity, borderColor: "#ef4444", transform: "rotate(15deg)" }}

>

<span style={{ color: "#ef4444", fontFamily: "'Bebas Neue', cursive", fontSize: "2rem", letterSpacing: "0.1em" }}>NOPE</span>

</motion.div>



{/* User info */}

