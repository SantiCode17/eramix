<motion.div

className="absolute top-8 left-6 px-4 py-2 rounded-2xl border-4"

style={{ opacity: likeOpacity, borderColor: "#22c55e", transform: "rotate(-15deg)" }}

>

<span style={{ color: "#22c55e", fontFamily: "'Bebas Neue', cursive", fontSize: "2rem", letterSpacing: "0.1em" }}>MATCH</span>

</motion.div>

<motion.div

